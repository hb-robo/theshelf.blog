---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllMediaItems } from '../../lib/mediaData';
import { getExpandedMediaById } from '../../lib/expandMediaItems';
import { getCollection, render } from 'astro:content';
import { getScoreColor, getPriorityCreatives, formatCreativeLine } from '../../lib/cardElements';
import { deriveEventLabel, HAVE_IT_STATUSES } from '../../lib/eventLabel';

export async function getStaticPaths() {
  const mediaItems = getAllMediaItems();
  return mediaItems.map(item => ({ params: { id: item.id } }));
}

const { id } = Astro.params;
const item = await getExpandedMediaById(id!);
if (!item) return Astro.redirect('/media');

const [allEvents, allReviews] = await Promise.all([
  getCollection('events'),
  getCollection('reviews'),
]);

const mediaEvents = allEvents.filter(e => e.data.mediaId === id);
const reviewAppearances = allReviews
  .filter(r => r.data.media.some(m => m.id === id))
  .map(r => {
    const m = r.data.media.find(m => m.id === id)!;
    return {
      kind: 'review' as const,
      date: r.data.date,
      title: r.data.title,
      slug: r.id,
      status: m.status,
      score: m.score,
      published: r.data.published,
    };
  });

const renderedEvents = await Promise.all(
  mediaEvents.map(async e => {
    const { Content } = await render(e);
    const hasBody = !!e.body?.trim();
    const priorOwned = allEvents.some(other =>
      other.data.mediaId === id &&
      other.data.date < e.data.date &&
      other.data.status !== undefined &&
      HAVE_IT_STATUSES.has(other.data.status)
    );
    const label = deriveEventLabel({ score: e.data.score, status: e.data.status, priorOwned });
    return { kind: 'event' as const, date: e.data.date, data: e.data, hasBody, label, Content };
  })
);

const changelog = [...renderedEvents, ...reviewAppearances]
  .sort((a, b) => b.date.getTime() - a.date.getTime());

const priorityCreatives = getPriorityCreatives(item);
const creativesLine = formatCreativeLine(priorityCreatives?.role, priorityCreatives?.names);

const releaseDate = item.releaseDate
  ? (() => {
      const [y, m, d] = item.releaseDate.split('-').map(Number);
      return new Date(y, m - 1, d).toLocaleDateString('en-CA', {
        year: 'numeric', month: 'long', day: 'numeric',
      });
    })()
  : null;

const SOURCE_LABELS: Record<string, string> = {
  rym: 'RYM', letterboxd: 'Letterboxd', goodreads: 'GoodReads',
  glitchwave: 'Glitchwave', backloggd: 'Backloggd',
};
---

<BaseLayout title={item.title}>
  <div class="max-w-4xl mx-auto px-4 pt-8 pb-2">
    <a href="/media" class="text-xs font-mono text-stone-400 hover:text-stone-900 transition-colors">← all media</a>
  </div>

  <!-- Meta + current status -->
  <div class="max-w-4xl mx-auto px-4 py-6 flex gap-8 items-start">
    {item.coverImage && (
      <img
        src={item.coverImage}
        alt={`Cover for ${item.title}`}
        class="hidden md:block max-h-40 object-contain shrink-0"
      />
    )}
    <div class="flex-1 min-w-0">
      <h1 class="text-3xl font-mono text-stone-900 mb-1">{item.title}</h1>
      {creativesLine && (
        <p class="text-stone-500 font-mono text-sm mb-2">{creativesLine}</p>
      )}
      <p class="text-xs font-mono text-stone-400 uppercase tracking-widest mb-5">
        {item.mediaType}{item.subtype ? ` · ${item.subtype}` : ''}{releaseDate ? ` · ${releaseDate}` : ''}
      </p>

      <div class="flex items-center gap-3 flex-wrap">
        {item.score && (
          <div class={`w-9 h-9 flex items-center justify-center font-bold font-mono text-sm ${getScoreColor(item.score)}`}>
            {item.score}
          </div>
        )}
        {item.status === 'shelved' && <span class="text-emerald-600 font-mono text-sm">shelved</span>}
        {item.status === 'wishlist' && <span class="text-sky-500 font-mono text-sm">wishlist</span>}
        {item.status === 'pending' && <span class="text-amber-500 font-mono text-sm">pending</span>}
        {item.status === 'chopping-block' && <span class="text-orange-500 font-mono text-sm">chopping block</span>}
        {item.status === 'pass' && <span class="text-stone-400 font-mono text-sm">pass</span>}
        {item.articleSlug && (
          <a
            href={`/reviews/${item.articleSlug}`}
            class="text-xs font-mono text-stone-400 hover:text-stone-900 transition-colors border border-stone-200 px-2 py-1"
          >
            read review →
          </a>
        )}
      </div>
    </div>
  </div>

  <!-- Changelog -->
  <div class="max-w-4xl mx-auto px-4 pb-16">
    <div class="flex justify-between items-center border-b border-stone-200 py-3">
      <span class="text-xs font-mono text-stone-400 uppercase tracking-widest">history</span>
      <span class="text-xs font-mono text-stone-400">{changelog.length} {changelog.length === 1 ? 'entry' : 'entries'}</span>
    </div>

    {changelog.length === 0 && (
      <p class="text-stone-400 font-mono text-sm py-8">no history yet.</p>
    )}

    {changelog.map(entry => {
      const hasBody = entry.kind === 'event' && entry.hasBody;
      const compact = !hasBody;
      return (
        <div class={`border-b border-stone-100 font-mono ${compact ? 'py-2' : 'py-4'}`}>
          <div class="flex items-baseline gap-4">
            <time class="text-xs text-stone-400 shrink-0 w-24">
              {entry.date.toLocaleDateString('fr-CA')}
            </time>

            <div class="flex-1 min-w-0">
              {entry.kind === 'event' && (
                <>
                  <!-- Header row: source · type on left, verdict indicators right-aligned -->
                  <div class="flex items-center justify-between gap-2">
                    <div class="flex items-center gap-2">
                      {entry.data.source !== 'site' && (
                        entry.data.sourceUrl ? (
                          <a
                            href={entry.data.sourceUrl}
                            class="text-xs text-stone-400 border border-stone-200 px-1.5 py-0.5 hover:text-stone-700 hover:border-stone-400 transition-colors"
                            target="_blank"
                            rel="noopener noreferrer"
                          >
                            {SOURCE_LABELS[entry.data.source] ?? entry.data.source} ↗
                          </a>
                        ) : (
                          <span class="text-xs text-stone-400 border border-stone-200 px-1.5 py-0.5">
                            {SOURCE_LABELS[entry.data.source] ?? entry.data.source}
                          </span>
                        )
                      )}
                      <span class="text-xs uppercase tracking-widest text-stone-500">
                        {entry.label}
                      </span>
                    </div>
                    <div class="flex items-center gap-2">
                      {entry.data.score && (
                        <span class={`w-6 h-6 flex items-center justify-center font-bold text-xs ${getScoreColor(entry.data.score)}`}>
                          {entry.data.score}
                        </span>
                      )}
                      {entry.data.status === 'shelved' && <span class="text-emerald-600 text-xs">shelved</span>}
                      {entry.data.status === 'wishlist' && <span class="text-sky-500 text-xs">wishlist</span>}
                      {entry.data.status === 'pending' && <span class="text-amber-500 text-xs">pending</span>}
                      {entry.data.status === 'chopping-block' && <span class="text-orange-500 text-xs">chopping block</span>}
                      {entry.data.status === 'pass' && <span class="text-stone-400 text-xs">pass</span>}
                    </div>
                  </div>

                  <!-- Body (notes only) -->
                  {hasBody && (
                    <div class="mt-2 text-sm text-stone-700 leading-relaxed prose prose-stone prose-sm font-mono max-w-none">
                      <entry.Content />
                    </div>
                  )}
                </>
              )}

              {entry.kind === 'review' && (
                <div class="flex items-center justify-between gap-2">
                  <div class="flex items-center gap-2 min-w-0">
                    <span class="text-xs uppercase tracking-widest text-stone-500 shrink-0">
                      {entry.published ? 'review' : 'review (draft)'}
                    </span>
                    <a
                      href={`/reviews/${entry.slug}`}
                      class="text-xs font-bold text-stone-700 hover:text-stone-500 transition-colors truncate"
                    >
                      {entry.title}
                    </a>
                  </div>
                  <div class="flex items-center gap-2 shrink-0">
                    {entry.score && (
                      <span class={`w-6 h-6 flex items-center justify-center font-bold text-xs ${getScoreColor(entry.score)}`}>
                        {entry.score}
                      </span>
                    )}
                    {entry.status === 'shelved' && <span class="text-emerald-600 text-xs">shelved</span>}
                    {entry.status === 'wishlist' && <span class="text-sky-500 text-xs">wishlist</span>}
                    {entry.status === 'pending' && <span class="text-amber-500 text-xs">pending</span>}
                    {entry.status === 'chopping-block' && <span class="text-orange-500 text-xs">chopping block</span>}
                    {entry.status === 'pass' && <span class="text-stone-400 text-xs">pass</span>}
                  </div>
                </div>
              )}
            </div>
          </div>
        </div>
      );
    })}
  </div>
</BaseLayout>
