---
import BaseLayout from '../layouts/BaseLayout.astro';
import SpineDisplay from '../components/SpineDisplay.astro';
import type { ExpandedMediaItem } from '../lib/types.ts';
import { getExpandedMediaList } from '../lib/expandMediaItems.ts';

const allMedia: ExpandedMediaItem[] = await getExpandedMediaList();

const shelfItems = allMedia.filter(m => m.status === 'shelved');
const wishlistItems = allMedia.filter(m => m.status === 'wishlist');
const backlogItems = allMedia.filter(m => m.status === 'pending');

const totalOnShelf = shelfItems.length;
---

<BaseLayout title="theshelf.blog">
  <div class="shelf-container h-full">
    <header class="max-w-4xl mx-auto px-4 pt-8 pb-4">
      <h1 class="text-4xl font-mono mb-2 text-stone-900">digital shelf visualizer</h1>
      <p class="text-base text-stone-500">less weird than being in my house... mostly :)</p>
    </header>

    <div class="flex max-w-4xl mx-auto px-4 space-x-4 py-6 font-mono text-sm">
      <button
        data-shelf-target="the-shelf"
        class="shelf-toggle-btn px-4 py-2 border border-amber-900 bg-amber-900 text-amber-50"
      >
        the shelf
      </button>
      <button
        data-shelf-target="wishlist"
        class="shelf-toggle-btn px-4 py-2 border border-stone-200 text-stone-500 hover:border-stone-400 transition-colors"
      >
        wishlist
      </button>
      <button
        data-shelf-target="backlog"
        class="shelf-toggle-btn px-4 py-2 border border-stone-200 text-stone-500 hover:border-stone-400 transition-colors"
      >
        backlog
      </button>
    </div>

    <section id="the-shelf" data-shelf-id="the-shelf" class="mt-2">
      <div class="max-w-4xl mx-auto px-4 mb-4 flex justify-between items-center border-b border-stone-200 py-3">
        <span class="text-xs font-mono text-stone-400 uppercase tracking-widest">the shelf</span>
        <span class="text-xs font-mono text-stone-400">{totalOnShelf} items</span>
      </div>
      <div class="shelf-row w-full bg-stone-100 border-y border-stone-200 shadow-inner overflow-hidden">
        <div class="shelf-scroll flex items-end gap-0.5 p-4 overflow-x-auto overflow-y-hidden scroll-smooth">
          {shelfItems
            .sort((a, b) => a.title.localeCompare(b.title))
            .map(item => <SpineDisplay itemData={item} />)}
        </div>
      </div>
    </section>

    {totalOnShelf === 0 && (
      <div class="max-w-4xl mx-auto px-4 text-center py-16">
        <p class="text-xl text-stone-500">The shelf is empty. Nothing has earned its place yet.</p>
      </div>
    )}

    <section id="wishlist" data-shelf-id="wishlist" class="mt-2 hidden">
      <div class="max-w-4xl mx-auto px-4 mb-4 flex justify-between items-center border-b border-stone-200 py-3">
        <span class="text-xs font-mono text-stone-400 uppercase tracking-widest">wishlist</span>
        <span class="text-xs font-mono text-stone-400">{wishlistItems.length} items</span>
      </div>
      <div class="shelf-row w-full bg-stone-100 border-y border-stone-200 shadow-inner overflow-hidden">
        <div class="shelf-scroll flex items-end gap-0.5 p-4 overflow-x-auto overflow-y-hidden scroll-smooth">
          {wishlistItems
            .sort((a, b) => a.title.localeCompare(b.title))
            .map(item => <SpineDisplay itemData={item} />)}
        </div>
      </div>
    </section>

    <section id="backlog" data-shelf-id="backlog" class="mt-2 hidden">
      <div class="max-w-4xl mx-auto px-4 mb-4 flex justify-between items-center border-b border-stone-200 py-3">
        <span class="text-xs font-mono text-stone-400 uppercase tracking-widest">backlog</span>
        <span class="text-xs font-mono text-stone-400">{backlogItems.length} items</span>
      </div>
      <div class="shelf-row w-full bg-stone-100 border-y border-stone-200 shadow-inner overflow-hidden">
        <div class="shelf-scroll flex items-end gap-0.5 p-4 overflow-x-auto overflow-y-hidden scroll-smooth">
          {backlogItems
            .sort((a, b) => a.title.localeCompare(b.title))
            .map(item => <SpineDisplay itemData={item} />)}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  :root {
    --shelf-scale: 1;
  }

  .shelf-scroll {
    padding-left: max(1rem, calc((100vw - 1280px) / 2 + 1rem + 1rem + 11rem));
    overscroll-behavior-x: contain;
  }

  .shelf-scroll::-webkit-scrollbar {
    height: 8px;
  }

  .shelf-scroll::-webkit-scrollbar-thumb {
    border-radius: 4px;
    background: rgb(161 161 170); /* stone-400 */
  }
</style>

<script>
  function setupShelfSwitcher() {
    function showShelf(shelfId: string) {
      document.querySelectorAll('[data-shelf-id]').forEach(el => {
        el.classList.add('hidden');
      });

      const targetShelf = document.querySelector(`[data-shelf-id="${shelfId}"]`);
      if (targetShelf) targetShelf.classList.remove('hidden');

      document.querySelectorAll('.shelf-toggle-btn').forEach(button => {
        if (button.getAttribute('data-shelf-target') === shelfId) {
          button.classList.remove('border-stone-200', 'text-stone-500', 'hover:border-stone-400', 'transition-colors');
          button.classList.add('border-amber-900', 'bg-amber-900', 'text-amber-50');
        } else {
          button.classList.remove('border-amber-900', 'bg-amber-900', 'text-amber-50');
          button.classList.add('border-stone-200', 'text-stone-500', 'hover:border-stone-400', 'transition-colors');
        }
      });
    }

    document.querySelectorAll('.shelf-toggle-btn').forEach(button => {
      button.addEventListener('click', () => {
        const targetId = button.getAttribute('data-shelf-target');
        if (targetId) showShelf(targetId);
      });
    });
  }

  setupShelfSwitcher();
</script>
