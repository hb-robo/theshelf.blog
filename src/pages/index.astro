---
import BaseLayout from "../layouts/BaseLayout.astro";
import SpineDisplay from "../components/SpineDisplay.astro";
import { getCollection } from "astro:content";
import type { ExpandedMediaItem } from "../lib/types";
import { getExpandedMediaList } from "../lib/expandMediaItems";
import { getScoreColor } from "../lib/cardElements";
import { getAllMediaItems } from "../lib/mediaData";
import { deriveEventLabel, HAVE_IT_STATUSES } from "../lib/eventLabel";

const [allReviews, allEvents] = await Promise.all([
  getCollection("reviews"),
  getCollection("events"),
]);

const publishedReviews = allReviews.filter((r) => r.data.published);

// Build a title lookup from the flat media list
const allMediaItems = getAllMediaItems();
const mediaTitleMap = new Map(allMediaItems.map(m => [m.id, m.title]));

// Published events (each is one entry)
type FeedEvent = {
  kind: 'event';
  date: Date;
  mediaId: string;
  mediaTitle: string;
  label: string;
  score?: number;
  status?: string;
  body?: string;
};

// Published reviews (coalesced: one entry per review, with all media outcomes)
type FeedReview = {
  kind: 'review';
  date: Date;
  title: string;
  slug: string;
  media: Array<{ id: string; title: string; score?: number; status?: string }>;
};

type FeedEntry = FeedEvent | FeedReview;

const eventEntries: FeedEvent[] = allEvents
  .filter(e => e.data.published)
  .map(e => {
    const priorOwned = allEvents.some(other =>
      other.data.mediaId === e.data.mediaId &&
      other.data.date < e.data.date &&
      other.data.status !== undefined &&
      HAVE_IT_STATUSES.has(other.data.status)
    );
    return {
      kind: 'event' as const,
      date: e.data.date,
      mediaId: e.data.mediaId,
      mediaTitle: mediaTitleMap.get(e.data.mediaId) ?? e.data.mediaId,
      label: deriveEventLabel({ score: e.data.score, status: e.data.status, priorOwned }),
      score: e.data.score,
      status: e.data.status,
      body: e.body?.trim() || undefined,
    };
  });

const reviewEntries: FeedReview[] = publishedReviews.map(r => ({
  kind: 'review' as const,
  date: r.data.date,
  title: r.data.title,
  slug: r.id,
  media: r.data.media.map((m: { id: string; score?: number; status?: string }) => ({
    id: m.id,
    title: mediaTitleMap.get(m.id) ?? m.id,
    score: m.score,
    status: m.status,
  })),
}));

const feed: FeedEntry[] = [...eventEntries, ...reviewEntries]
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, 10);


const expandedMediaList: ExpandedMediaItem[] = await getExpandedMediaList();
const publishedMedia = expandedMediaList.filter((m) => m.published);
const stripItems = expandedMediaList
  .filter(m => m.status === 'shelved')
  .sort((a, b) => {
    if (!a.reviewDate) return 1;
    if (!b.reviewDate) return -1;
    return new Date(b.reviewDate).getTime() - new Date(a.reviewDate).getTime();
  });

const totalReviews: number = publishedReviews.length;
const totalMedia: number = publishedMedia.length;
const totalOnShelf: number = publishedMedia.filter(
  (m) => m.status === 'shelved'
).length;
const approvalRate =
  totalMedia > 0 ? Math.round((totalOnShelf / totalMedia) * 100) : 0;
---

<BaseLayout title="theshelf.blog" bigNav>
  <!-- Hero Section -->
  <section>
    <div class="max-w-4xl mx-auto px-4 py-12 md:py-8">
      <p class="max-w-2xl text-xl md:text-2xl font-mono text-stone-700 leading-snug">
        a battle royale for my shelf space<br>feat. books, albums, games, and films
      </p>
    </div>
  </section>

  <!-- Shelf Strip -->
  <section style="--shelf-scale: 0.8;">
    <div class="max-w-4xl mx-auto px-4 flex justify-between items-center py-3">
      <span class="text-xs font-mono text-stone-400 uppercase tracking-widest">on the shelf lately</span>
      <a href="/shelf" class="text-xs font-mono text-stone-400 hover:text-stone-900 transition-colors">explore the full shelf →</a>
    </div>
    <div class="max-w-4xl mx-auto px-4">
      <div class="bg-stone-100 border border-stone-200 shadow-inner overflow-hidden">
        <div class="flex items-end gap-0.5 px-4 pt-4 pb-3">
          {stripItems.map(item => <SpineDisplay itemData={item} />)}
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Overview -->
  <section class="max-w-4xl mx-auto px-4 py-8">
    <div class="flex justify-between items-center border-b border-stone-200 py-3 mb-6">
      <span class="text-xs font-mono text-stone-400 uppercase tracking-widest">some numbers</span>
      <a href="/stats" class="text-xs font-mono text-stone-400 hover:text-stone-900 transition-colors">more data →</a>
    </div>
    <div class="border border-stone-200 grid grid-cols-2 md:grid-cols-4 divide-x divide-y md:divide-y-0 divide-stone-200 font-mono">
      <div class="p-6 text-center">
        <div class="text-4xl text-stone-900 mb-2">{totalReviews}</div>
        <div class="text-xs text-stone-400 uppercase tracking-widest">reviews</div>
      </div>
      <div class="p-6 text-center">
        <div class="text-4xl text-stone-900 mb-2">{totalMedia}</div>
        <div class="text-xs text-stone-400 uppercase tracking-widest">works covered</div>
      </div>
      <div class="p-6 text-center">
        <div class="text-4xl text-stone-900 mb-2">{totalOnShelf}</div>
        <div class="text-xs text-stone-400 uppercase tracking-widest">shelved</div>
      </div>
      <div class="p-6 text-center">
        <div class="text-4xl text-stone-900 mb-2">{approvalRate}%</div>
        <div class="text-xs text-stone-400 uppercase tracking-widest">approval</div>
      </div>
    </div>
  </section>

  <!-- Activity Feed -->
  <section class="max-w-4xl mx-auto px-4 py-8">
    <div class="flex justify-between items-center border-b border-stone-200 py-3 mb-2">
      <span class="text-xs font-mono text-stone-400 uppercase tracking-widest">recent activity</span>
      <a href="/reviews" class="text-xs font-mono text-stone-400 hover:text-stone-900 transition-colors">all reviews →</a>
    </div>

    {feed.map(entry => (
      <div class="border-b border-stone-100 font-mono py-3">
        <div class="flex items-baseline gap-4">
          <time class="text-xs text-stone-400 shrink-0 w-24">
            {entry.date.toLocaleDateString('fr-CA')}
          </time>

          <div class="flex-1 min-w-0">
            {entry.kind === 'event' && (
              <div>
                <div class="flex items-center justify-between gap-2">
                  <div class="flex items-center gap-2 min-w-0">
                    <span class="text-xs uppercase tracking-widest text-stone-500 shrink-0">
                      {entry.label}
                    </span>
                    <a
                      href={`/media/${entry.mediaId}`}
                      class="text-xs font-bold text-stone-700 hover:text-stone-500 transition-colors truncate"
                    >
                      {entry.mediaTitle}
                    </a>
                    {entry.body && (
                      <span class="text-xs text-stone-300 shrink-0">¶</span>
                    )}
                  </div>
                  <div class="flex items-center gap-2 shrink-0 min-h-6">
                    {entry.status === 'shelved' && <span class="text-emerald-600 text-xs">shelved</span>}
                    {entry.status === 'wishlist' && <span class="text-sky-500 text-xs">wishlist</span>}
                    {entry.status === 'pending' && <span class="text-amber-500 text-xs">pending</span>}
                    {entry.status === 'chopping-block' && <span class="text-orange-500 text-xs">chopping block</span>}
                    {entry.status === 'pass' && <span class="text-stone-400 text-xs">pass</span>}
                    {entry.score && (
                      <span class={`w-6 h-6 flex items-center justify-center font-bold text-xs ${getScoreColor(entry.score)}`}>
                        {entry.score}
                      </span>
                    )}
                  </div>
                </div>
              </div>
            )}

            {entry.kind === 'review' && (
              <div>
                <div class="flex items-center gap-2 min-w-0 mb-1.5">
                  <span class="text-xs uppercase tracking-widest text-stone-500 shrink-0">review</span>
                  <a
                    href={`/reviews/${entry.slug}`}
                    class="text-xs font-bold text-stone-700 hover:text-stone-500 transition-colors truncate"
                  >
                    {entry.title}
                  </a>
                </div>
                <div class="flex flex-col gap-0.5">
                  {entry.media.map(m => (
                    <div class="flex items-center justify-between gap-2">
                      <a
                        href={`/media/${m.id}`}
                        class="text-xs text-stone-500 hover:text-stone-700 transition-colors truncate"
                      >
                        {m.title}
                      </a>
                      <div class="flex items-center gap-2 shrink-0 min-h-6">
                        {m.status === 'shelved' && <span class="text-emerald-600 text-xs">shelved</span>}
                        {m.status === 'wishlist' && <span class="text-sky-500 text-xs">wishlist</span>}
                        {m.status === 'pending' && <span class="text-amber-500 text-xs">pending</span>}
                        {m.status === 'chopping-block' && <span class="text-orange-500 text-xs">chopping block</span>}
                        {m.status === 'pass' && <span class="text-stone-400 text-xs">pass</span>}
                        {m.score && (
                          <span class={`w-6 h-6 flex items-center justify-center font-bold text-xs ${getScoreColor(m.score)}`}>
                            {m.score}
                          </span>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    ))}
  </section>
</BaseLayout>
