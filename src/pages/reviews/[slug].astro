---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from 'astro:content';
import ArticleHeader from '../../components/ArticleHeader.astro';
import MediaResultSummary from '../../components/MediaResultSummary.astro';
import MediaPreviewGrid from '../../components/MediaPreviewGrid.astro';
import { getMediaTitle, getMediaCoverImage } from '../../lib/mediaData';

export async function getStaticPaths() {
  const reviews = await getCollection("reviews");
  return reviews.map((entry: CollectionEntry<'reviews'>) => ({
    params: { slug: entry.id },
    props: { entry }
  }));
}

interface Props {
  entry: CollectionEntry<'reviews'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const enrichedMedia = entry.data.media.map((item) => ({
  ...item,
  title: getMediaTitle(item.id) || 'Unknown',
  coverImage: getMediaCoverImage(item.id) || '/placeholder.jpg',
}));
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.excerpt}
  ogImage={entry.data.heroImage}
>
  <div class="max-w-4xl mx-auto px-4 pt-8">
    <MediaPreviewGrid
      heroImage={entry.data.heroImage}
      heroAlt={`Cover art for ${entry.data.title}`}
      items={enrichedMedia}
      class="w-full border border-zinc-200 p-8 bg-zinc-50"
    />
  </div>
  <article class="mx-auto max-w-2xl px-4 py-8 prose prose-zinc font-sans">
    <ArticleHeader review={entry} />
    <Content />
    <MediaResultSummary reviewMedia={entry.data.media} />
    <footer class="not-prose mt-8 border-t border-zinc-200 flex justify-between font-mono">
      <a
        href="/"
        class="my-3 font-medium transition-colors no-underline hover:underline text-sm"
      >
        ← back to home
      </a>
      <a
        href="/reviews"
        class="my-3 font-medium transition-colors no-underline hover:underline text-sm"
      >
        read more →
      </a>
    </footer>
  </article>
</BaseLayout>
