---
import type { CollectionEntry } from "astro:content";
import { generateExcerpt } from "../lib/cardElements";
import { getMediaTitle, getMediaCoverImage } from "../lib/mediaData";
import MediaPreviewGrid from "./MediaPreviewGrid.astro";

export interface Props {
  itemData: CollectionEntry<"reviews">;
}
const { itemData } = Astro.props;
const { title, date, heroImage, excerpt } = itemData.data;
const media: CollectionEntry<"reviews">["data"]["media"] = itemData.data.media;
const formattedDate = date.toLocaleDateString("fr-CA");

const shelvedCount = media.filter((m) => m.status == "shelved").length;
const totalCount = media.length;
const missedCount = totalCount - shelvedCount;

const displayExcerpt = excerpt || generateExcerpt(shelvedCount, missedCount);

const enrichedMediaList = media.map((mediaItem) => ({
  ...mediaItem,
  title: getMediaTitle(mediaItem.id) || "Unknown Title",
  coverImage: getMediaCoverImage(mediaItem.id),
}));
---

<article
  class="relative border border-stone-200 overflow-hidden hover:border-stone-400 transition-colors"
>
  <div class="flex flex-col md:flex-row md:max-h-48">
    <MediaPreviewGrid
      heroImage={heroImage}
      heroAlt={`Cover art for ${title}`}
      items={enrichedMediaList}
      height="h-44"
      class="md:w-80 md:min-w-80 md:h-48 bg-stone-50 p-2 border-b md:border-b-0 md:border-r border-stone-200"
    />
    <div class="p-5 flex flex-col justify-between w-full">
      <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-1">
        <div class="flex-1">
          <h3 class="text-xl font-mono mb-1">
            <a
              href={`/reviews/${itemData.id}`}
              class="hover:text-stone-600 transition-colors after:absolute after:inset-0"
            >
              {title}
            </a>
          </h3>

          <p class="text-stone-400 text-sm mb-2">
            <time datetime={formattedDate}>{formattedDate}</time>
            {media.length > 0 && ` • ${media.length} item${media.length !== 1 ? 's' : ''}`}
          </p>

          {
            displayExcerpt && (
              <p class="text-stone-500 text-sm line-clamp-2">
                {displayExcerpt}
              </p>
            )
          }
        </div>
      </div>

      <div
        class="flex justify-between items-center text-sm text-stone-400 border-t border-stone-200 mt-4 pt-2"
      >
        {
          media.length > 0 && (
            <div class="flex gap-2">
              {shelvedCount > 0 && (
                <span class="text-emerald-600 inline-flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5">
                    <path d="M4 3a1 1 0 0 0-1 1v16a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1v-4.703L16 20a1 1 0 0 0 1.186.77l3.912-.832a1 1 0 0 0 .77-1.186l-2.91-13.694a1 1 0 0 0-1.186-.77l-2.78.59A1 1 0 0 0 14 4h-4a1 1 0 0 0-1-1zm6 3h3v8h-3zm0 13v-3h3v3zM8 5v10H5V5zm0 12v2H5v-2zm9.332-.35l1.956-.416l.416 1.956l-1.956.416zm-.416-1.957l-1.663-7.825l1.956-.416l1.664 7.826z" />
                  </svg>
                  {shelvedCount}
                </span>
              )}
{missedCount > 0 && (
                <span class="text-red-500 inline-flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5">
                    <g fill="currentColor">
                      <path d="M8.478 8.478a1 1 0 0 1 1.414 0l2.154 2.153l2.153-2.153a1 1 0 1 1 1.414 1.414l-2.153 2.154l2.153 2.153a1 1 0 0 1-1.414 1.414l-2.153-2.153l-2.154 2.153A1 1 0 0 1 8.478 14.2l2.153-2.153l-2.153-2.154a1 1 0 0 1 0-1.414"/>
                      <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10s10-4.477 10-10S17.523 2 12 2M4 12a8 8 0 1 1 16 0a8 8 0 0 1-16 0" clip-rule="evenodd"/>
                    </g>
                  </svg>
                  {missedCount}
                </span>
              )}
            </div>
          )
        }
        <span class="text-stone-400 text-sm font-mono">read review →</span>
      </div>
    </div>
  </div>
</article>
