---
import { getScoreColor } from "../lib/cardElements";
import type { ExpandedMediaItem } from "../lib/types";

export interface Props {
  itemData: ExpandedMediaItem;
}

const { itemData } = Astro.props;
const scoreColor = itemData.score ? getScoreColor(Number(itemData.score)) : null;
---

<div class="not-prose border-t border-b border-zinc-200 py-3 my-8 flex items-center justify-between gap-4">
  <span class="font-mono text-xs uppercase tracking-widest text-zinc-400">result</span>
  <div class="flex items-center gap-3 shrink-0">
    {itemData.score && (
      <span class={`flex items-center justify-center w-8 h-8 font-bold text-sm ${scoreColor}`}>
        {itemData.score}
      </span>
    )}
    {itemData.result === "shelved" && <span class="font-mono text-sm text-emerald-600">shelved</span>}
    {itemData.result === "deferred" && <span class="font-mono text-sm text-yellow-500">deferred</span>}
    {itemData.result === "passed" && <span class="font-mono text-sm text-zinc-400">passed on</span>}
  </div>
</div>
