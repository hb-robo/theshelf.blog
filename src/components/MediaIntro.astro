---
import { getPriorityCreatives, formatCreativeLine } from "../lib/cardElements.ts";
import type { ExpandedMediaItem } from "../lib/types.ts";

export interface Props {
  itemData: ExpandedMediaItem;
}

const { itemData } = Astro.props;
const priorityCreatives = getPriorityCreatives(itemData);
const creativesLine = formatCreativeLine(priorityCreatives?.role, priorityCreatives?.names);
---

<div class="not-prose border-t border-b border-zinc-200 py-4 my-8 flex items-center gap-4">
  {itemData.coverImage && (
    <div class="w-14 h-20 shrink-0 flex items-center justify-center">
      <img
        src={itemData.coverImage}
        alt={`Cover art for ${itemData.title}`}
        class="max-h-full max-w-full object-contain"
      />
    </div>
  )}
  <div>
    <div class="font-mono text-lg text-zinc-900 leading-tight mb-1">{itemData.title}</div>
    {creativesLine && (
      <div class="text-sm text-zinc-400">{creativesLine}</div>
    )}
    {itemData.releaseDate && (
      <div class="text-xs text-zinc-400 mt-0.5">{itemData.releaseDate}</div>
    )}
  </div>
</div>
