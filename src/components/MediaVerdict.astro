---
type Status = "shelved" | "wishlist" | "pending" | "chopping-block" | "pass";

export interface Props {
  status?: Status;
  score?: number;
  compact?: boolean;
}

const { status, score, compact = false } = Astro.props as Props;

const statusColors: Record<Status, string> = {
  "shelved": "text-emerald-600",
  "wishlist": "text-sky-500",
  "pending": "text-amber-500",
  "chopping-block": "text-orange-500",
  "pass": "text-stone-400",
};

---

<span class={`inline-flex items-center gap-1 font-mono ${status ? statusColors[status] : 'text-stone-400'} ${compact ? "text-sm" : "text-base"}`}>
  {status ?? '—'}
  {score && <span class="ml-1">· {score}/10</span>}
</span>
