---
type Result = "shelved" | "deferred" | "passed";

export interface Props {
  result: Result;
  score?: number;
  compact?: boolean;
}

const { result, score, compact = false } = Astro.props as Props;

const resultColors: Record<Result, string> = {
  "shelved": "text-emerald-600",
  "deferred": "text-yellow-500",
  "passed": "text-stone-400"
};

---

<span class={`inline-flex items-center gap-1 font-mono ${resultColors[result]} ${compact ? "text-sm" : "text-base"}`}>
  {result}
  {score && <span class="ml-1">· {score}/10</span>}
</span>
