---
export interface Props {
  big?: boolean;
}
const { big = false } = Astro.props;
const path = Astro.url.pathname;
function isActive(href: string) {
  return href === '/' ? path === '/' : path.startsWith(href);
}
function linkClass(href: string) {
  return isActive(href)
    ? 'text-stone-900 transition-colors'
    : 'text-stone-500 hover:text-stone-900 transition-colors';
}
---

<nav class="font-mono">
  <div class="max-w-4xl mx-auto px-4 py-4">
    <div class={`flex items-center justify-between ${big ? "mt-10" : ""}`}>
      <a href="/" class={`${big ? "text-4xl border-b-[3px]" : "text-2xl border-b-[3px]"} font-mono flex items-end gap-2 border-amber-900 text-amber-950 hover:text-amber-800 transition-colors`}>
        <span class={`leading-none ${big ? "translate-y-[8px]" : "translate-y-[5px]"}`}>theshelf.blog</span>
        <svg xmlns="http://www.w3.org/2000/svg" width={big ? 50 : 25} height={big ? 50 : 25} viewBox="0 0 512 512" class="translate-y-px"><path fill="currentColor" d="M169 57v430h78V57zM25 105v190h46V105zm158 23h18v320h-18zm128.725 7.69l-45.276 8.124l61.825 344.497l45.276-8.124zM89 153v270h62V153zm281.502 28.68l-27.594 11.773l5.494 12.877l27.594-11.773zm12.56 29.433l-27.597 11.772l5.494 12.877l27.593-11.772l-5.492-12.877zm12.555 29.434l-27.594 11.77l99.674 233.628l27.594-11.773zM25 313v30h46v-30zm190 7h18v128h-18zM25 361v126h46V361zm64 80v46h62v-46z"/></svg>
      </a>

      <div class="hidden md:flex gap-6 text-sm font-mono">
        <a href="/reviews" class={linkClass('/reviews')}>reviews</a>
        <a href="/shelf" class={linkClass('/shelf')}>the shelf</a>
        <a href="/media" class={linkClass('/media')}>media</a>
        <a href="/stats" class={linkClass('/stats')}>stats</a>
        <a href="/about" class={linkClass('/about')}>about</a>
      </div>

      <button id="menu-btn" class="md:hidden text-stone-900" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden md:hidden mt-4 pb-4 space-y-2 text-sm">
      <a href="/reviews" class={`block py-2 ${linkClass('/reviews')}`}>reviews</a>
      <a href="/shelf" class={`block py-2 ${linkClass('/shelf')}`}>the shelf</a>
      <a href="/media" class={`block py-2 ${linkClass('/media')}`}>media</a>
      <a href="/stats" class={`block py-2 ${linkClass('/stats')}`}>stats</a>
      <a href="/about" class={`block py-2 ${linkClass('/about')}`}>about</a>
    </div>
  </div>
</nav>
<script>
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('hidden') === false;
    menuBtn.setAttribute('aria-expanded', String(isOpen));
    menuBtn.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
  });
</script>
