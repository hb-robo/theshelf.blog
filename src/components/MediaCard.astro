---
import {
  mediaColors,
  getScoreColor,
  getMediaTypeBorder,
  organizeCreatives,
  formatCreativeLine
} from "../lib/cardElements";
import type { ExpandedMediaItem } from "../lib/types";

export interface Props {
  itemData: ExpandedMediaItem;
}
const { itemData } = Astro.props;

const organized = organizeCreatives(itemData);
const rolesInOrder = Object.keys(organized);

const mediaBorder = getMediaTypeBorder(itemData.mediaType);
const mediaColor = mediaColors[itemData.mediaType];

---

<article
  class={`@container media-item border ${mediaBorder} overflow-hidden hover:border-stone-400 transition-colors`}
>
  <div class="flex flex-row">
    {
      itemData.coverImage && (
        <div
          class={`w-32 min-w-32 @[32rem]:w-48 @[32rem]:min-w-48 flex items-center justify-center p-2 @[32rem]:p-3 ${mediaColor} border-r ${mediaBorder}`}
        >
          <img
            src={itemData.coverImage}
            alt={`Cover art for ${itemData.title}`}
            class="max-w-full max-h-32 @[32rem]:max-h-48 object-contain"
          />
        </div>
      )
    }

    <div class="p-2.5 @[32rem]:p-4 flex w-full flex-col justify-between">
      <div class="mb-1">
          <h3 class="text-base @[32rem]:text-xl font-mono mb-1">
            <a
              href={`/media/${itemData.id}`}
              class="hover:text-stone-600 transition-colors"
            >
              {itemData.title}
            </a>
          </h3>

          <div class="creatives-output mb-1 @[32rem]:mb-2 font-mono">
            {rolesInOrder.length > 0 && (
              <ul>
                {rolesInOrder.map(role => (
                  <li class="text-stone-500 text-sm">
                    {formatCreativeLine(role, organized[role])}
                  </li>
                ))}
              </ul>
            )}
          </div>

          
          <p class="text-stone-400 text-sm flex flex-row flex-wrap gap-x-2">
            {
              itemData.releaseDate && (
                <span>
                  <time datetime={itemData.releaseDate}>
                    {itemData.releaseDate}
                  </time>
                </span>
              )
            }
            {
              itemData.releaseDate && itemData.genre && (
                <span class="text-stone-400">•</span>
              )
            }
            {
              itemData.genre && (
                <span>
                  {Array.isArray(itemData.genre)
                    ? itemData.genre.map(g => g.toLowerCase()).join(", ")
                    : itemData.genre.toLowerCase()}
                </span>
              )
            }
          </p>
      </div>

      <div
        class="flex justify-between items-center text-sm text-stone-400 border-t border-stone-200 mt-2 pt-1.5 @[32rem]:mt-3 @[32rem]:pt-2"
      >
        <div class="flex gap-2 h-8">
          {
            itemData.published && itemData.score && (
              <div
                class={`flex items-center justify-center w-5 h-5 font-bold text-sm p-4 ${getScoreColor(Number(itemData.score))}`}
                title={`Score: ${itemData.score}/10`}
              >
                {itemData.score}
              </div>
            )
          }
          {itemData.status === "shelved" && (
            <span class="text-emerald-600 inline-flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5">
                <path d="M4 3a1 1 0 0 0-1 1v16a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1v-4.703L16 20a1 1 0 0 0 1.186.77l3.912-.832a1 1 0 0 0 .77-1.186l-2.91-13.694a1 1 0 0 0-1.186-.77l-2.78.59A1 1 0 0 0 14 4h-4a1 1 0 0 0-1-1zm6 3h3v8h-3zm0 13v-3h3v3zM8 5v10H5V5zm0 12v2H5v-2zm9.332-.35l1.956-.416l.416 1.956l-1.956.416zm-.416-1.957l-1.663-7.825l1.956-.416l1.664 7.826z" />
              </svg>
              <span>shelved</span>
            </span>
          )}
          {itemData.status === "wishlist" && (
            <span class="text-sky-500 inline-flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5">
                <path d="M5 2a2 2 0 0 0-2 2v18l9-4l9 4V4a2 2 0 0 0-2-2z"/>
              </svg>
              <span>wishlist</span>
            </span>
          )}
          {itemData.status === "pending" && (
            <span class="text-amber-500 inline-flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5">
                <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2m0 18a8 8 0 1 1 8-8a8 8 0 0 1-8 8m.5-13H11v6l5.25 3.15l.75-1.23l-4.5-2.67Z"/>
              </svg>
              <span>pending</span>
            </span>
          )}
          {itemData.status === "chopping-block" && (
            <span class="text-orange-500 inline-flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5">
                <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2m0 18a8 8 0 1 1 8-8a8 8 0 0 1-8 8m-1-5h2v2h-2zm0-8h2v6h-2z"/>
              </svg>
              <span>chopping block</span>
            </span>
          )}
          {itemData.status === "pass" && (
            <span class="text-stone-400 inline-flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5">
                <g fill="currentColor">
                  <path d="M8.478 8.478a1 1 0 0 1 1.414 0l2.154 2.153l2.153-2.153a1 1 0 1 1 1.414 1.414l-2.153 2.154l2.153 2.153a1 1 0 0 1-1.414 1.414l-2.153-2.153l-2.154 2.153A1 1 0 0 1 8.478 14.2l2.153-2.153l-2.153-2.154a1 1 0 0 1 0-1.414"/>
                  <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10s10-4.477 10-10S17.523 2 12 2M4 12a8 8 0 1 1 16 0a8 8 0 0 1-16 0" clip-rule="evenodd"/>
                </g>
              </svg>
              <span>pass</span>
            </span>
          )}
        </div>
        {
          itemData.published && itemData.reviewDate && (
            <p class="text-stone-400 text-sm">
              <a href={`/reviews/${itemData.articleSlug}`}>read review →</a>
            </p>
          )
        }
      </div>
    </div>
  </div>
</article>
