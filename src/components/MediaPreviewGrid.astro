---
export interface MediaPreviewItem {
  coverImage: string;
  title?: string;
}

export interface Props {
  heroImage?: string;
  heroAlt?: string;
  items?: MediaPreviewItem[];
  maxItems?: number;
  class?: string;
  height?: string;
}

const {
  heroImage,
  heroAlt = "",
  items = [],
  maxItems = 12,
  class: className = "",
  height = "h-56",
} = Astro.props;

const count = items.length;
const visibleItems = items.slice(0, maxItems);
const overflow = count - maxItems;
---

<div class={className}>
  <div class={`${height} overflow-hidden`}>
  {heroImage ? (
    <div class="flex items-center justify-center h-full">
      <img
        src={heroImage}
        alt={heroAlt}
        class="max-w-full max-h-full object-contain"
      />
    </div>
  ) : count > 0 ? (
    <>
      {count === 1 && (
        <div class="flex items-center justify-center h-full">
          <img src={items[0].coverImage} alt={items[0].title} class="max-h-full object-contain" />
        </div>
      )}

      {count === 2 && (
        <div class="grid grid-cols-2 gap-2 h-full">
          {items.map((m) => (
            <div class="flex items-center justify-center h-full overflow-hidden">
              <img src={m.coverImage} alt={m.title} class="max-w-full max-h-full object-contain" />
            </div>
          ))}
        </div>
      )}

      {count === 4 && (
        <div class="grid grid-cols-2 grid-rows-2 gap-2 h-full">
          {items.map((m) => (
            <div class="flex items-center justify-center h-full">
              <img src={m.coverImage} alt={m.title} class="max-h-full max-w-full object-contain" />
            </div>
          ))}
        </div>
      )}

      {(count === 3 || count === 6) && (
        <div class={`grid grid-cols-3 gap-2 h-full ${count === 6 ? 'grid-rows-2' : 'grid-rows-1'}`}>
          {items.slice(0, 6).map((m) => (
            <div class="flex items-center justify-center h-full">
              <img src={m.coverImage} alt={m.title} class="max-h-full object-contain" />
            </div>
          ))}
        </div>
      )}

      {count === 5 && (
        <div class="grid grid-cols-6 grid-rows-2 gap-2 h-full">
          {items.slice(0, 3).map((m) => (
            <div class="col-span-2 flex items-center justify-center h-full">
              <img src={m.coverImage} alt={m.title} class="max-h-full object-contain" />
            </div>
          ))}
          {items.slice(3, 5).map((m) => (
            <div class="col-span-3 flex items-center justify-center h-full">
              <img src={m.coverImage} alt={m.title} class="max-h-full object-contain" />
            </div>
          ))}
        </div>
      )}

      {count >= 7 && count <= 9 && (
        <div class="grid grid-cols-3 grid-rows-3 gap-1 h-full">
          {items.slice(0, 9).map((m) => (
            <div class="flex items-center justify-center h-full">
              <img src={m.coverImage} alt={m.title} class="max-h-full object-contain" />
            </div>
          ))}
        </div>
      )}

      {count >= 10 && (
        <div class="relative h-full">
          <div class="grid grid-cols-4 grid-rows-3 gap-1 h-full">
            {visibleItems.map((m, idx) => (
              <div class="flex items-center justify-center h-full relative">
                <img src={m.coverImage} alt={m.title} class="max-h-full object-contain" />
                {idx === maxItems - 1 && overflow > 0 && (
                  <div class="absolute inset-0 flex items-center justify-center font-bold text-lg">
                    +{overflow}
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      )}
    </>
  ) : null}
  </div>
</div>
