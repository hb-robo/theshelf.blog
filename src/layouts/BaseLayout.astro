---
import "../styles/global.css";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  bigNav?: boolean;
}

const { title, description, ogImage, bigNav = false } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const defaultDescription = "musings on the ultimate zero-sum game: what books, albums, games, and films make my shelf?";

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description ?? defaultDescription} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description ?? defaultDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="theshelf.blog" />
    {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site)} />}
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description ?? defaultDescription} />
    {ogImage && <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />}
    <link
      rel="alternate"
      type="application/rss+xml"
      title="theshelf.blog"
      href={new URL("rss.xml", Astro.site)}
    />
  </head>
  <body
    class="flex flex-col min-h-screen bg-amber-50 text-stone-900 overscroll-none"
  >
    <Navigation big={bigNav} />
    <div class="grow">
      <slot />
    </div>
    <Footer />
  </body>
</html>
